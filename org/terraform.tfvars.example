]

# Cloud Identity customer ID — run:
#   gcloud organizations describe <ORG_ID> --format='value(owner.directoryCustomerId)'
cloud_identity_customer_id = "TODO"

# Restrict all resource creation to US regions.
# "in:us-locations" is a GCP location group covering all US regions.
# Add "in:us-locations" alongside specific overrides if needed.
allowed_regions = ["in:us-locations"]

# Personal platform — keep spend caps conservative.
# Alerts fire at 50%, 80%, and 100% of each cap.
org_budget_amount     = 50  # USD/month, all billing account spend
prod_budget_amount    = 30  # USD/month, prod folder only
nonprod_budget_amount = 20  # USD/month, nonprod + sandbox folders
